{"slides":["<!DOCTYPE html>\n<html lang=\"ja\">\n\n<head>\n    <meta charset=\"utf-8\" />\n    <meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\" />\n    <title>Multi Slide Test</title>\n    <link href=\"https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css\" rel=\"stylesheet\" />\n    <style>\n        body {\n            margin: 0;\n            padding: 0;\n            font-family: 'Arial', sans-serif;\n        }\n\n        .slide {\n            width: 1280px;\n            height: 720px;\n            position: relative;\n            overflow: hidden;\n        }\n    </style>\n</head>\n\n<body>\n\n    <div class=\"slide\"\n        style=\"background: linear-gradient(135deg, #667eea, #764ba2); display:flex; align-items:center; justify-content:center; flex-direction:column;\">\n        <h1 style=\"color:white; font-size:60px; font-weight:bold;\">Slide 1</h1>\n        <p style=\"color:rgba(255,255,255,0.8); font-size:24px; margin-top:20px;\">First slide content</p>\n    </div>\n\n    <div class=\"slide\"\n        style=\"background: linear-gradient(135deg, #f093fb, #f5576c); display:flex; align-items:center; justify-content:center; flex-direction:column;\">\n        <h1 style=\"color:white; font-size:60px; font-weight:bold;\">Slide 2</h1>\n        <p style=\"color:rgba(255,255,255,0.8); font-size:24px; margin-top:20px;\">Second slide content</p>\n    </div>\n\n    <div class=\"slide\"\n        style=\"background: linear-gradient(135deg, #4facfe, #00f2fe); display:flex; align-items:center; justify-content:center; flex-direction:column;\">\n        <h1 style=\"color:white; font-size:60px; font-weight:bold;\">Slide 3</h1>\n        <p style=\"color:rgba(255,255,255,0.8); font-size:24px; margin-top:20px;\">Third slide content</p>\n    </div>\n\n</body>\n\n</html>"]}